{
  "name": "himalayan-passes-next",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build:tailwind": "node node_modules/tailwindcss/lib/cli.js -i ./tailwind.input.css -o ./public/style/tailwind.css --minify",
    "build": "npm run build:tailwind && node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/next/dist/bin/next lint"
  },
  "dependencies": {
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
